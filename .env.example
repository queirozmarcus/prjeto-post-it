# ============================================================
# prjeto-post-it — Variáveis de Ambiente
# Copie para .env e preencha os valores
# NUNCA commite o arquivo .env
# ============================================================

# --- PostgreSQL ---
POSTGRES_DB=postit_db
POSTGRES_USER=user
POSTGRES_PASSWORD=password          # ALTERAR em produção

# --- Spring Boot / API ---
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/postit_db
SPRING_DATASOURCE_USERNAME=user
SPRING_DATASOURCE_PASSWORD=password # ALTERAR em produção

# --- JWT ---
# Gere com: openssl rand -hex 32
# Mínimo 32 caracteres. OBRIGATÓRIO em produção.
JWT_SECRET=changeme-replace-in-production-min-32-chars

# --- Cookie ---
# false em desenvolvimento local (sem HTTPS), true em produção (requer HTTPS)
COOKIE_SECURE=false

# --- Flyway ---
SPRING_FLYWAY_URL=jdbc:postgresql://db:5432/postit_db
SPRING_FLYWAY_USER=user
SPRING_FLYWAY_PASSWORD=password     # ALTERAR em produção
